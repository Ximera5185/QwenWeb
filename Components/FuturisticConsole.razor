@namespace QwenWeb.Components
@implements IDisposable
@inject Microsoft.JSInterop.IJSRuntime JS

<div class="cyber-console">
    <div class="console-header">
        <span>🖥️ КОНСОЛЬ МОНИТОРИНГА</span>
        <span class="badge-status">@statusText</span>
    </div>

    <!-- LED-индикаторы -->
    <div class="console-leds">
        <div class="led-row">
            <span class="led-label">NET</span>
            <span class="led-dot" style="background-color: @netLedColor"></span>
        </div>
        <div class="led-row">
            <span class="led-label">DB</span>
            <span class="led-dot" style="background-color: #00ffcc"></span>
        </div>
        <div class="led-row">
            <span class="led-label">CPU</span>
            <span class="led-dot" style="background-color: @cpuLedColor"></span>
        </div>
    </div>

    <!-- Метаданные сессии -->
    <div class="console-meta">
        <span>SESSION: @sessionId</span>
        <span>PROTO: TLS 1.3</span>
        <span>ENCRYPT: AES-256-GCM</span>
    </div>

    <!-- Логи -->
    <div class="console-logs" @ref="logScrollContainer">
        @foreach (LogEntry entry in logs)
        {
            <div class="log-line log-@entry.Level">@entry.Text</div>
        }
        <div class="cursor-blink">█</div>
    </div>

    <!-- Метрики + Sparkline -->
    <div class="console-metrics">
        <div class="metric-group">
            <span>CPU</span>
            <div class="sparkline">
                @foreach (double val in cpuHistory)
                {
                    <div class="spark-bar" style="height: @val.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                }
            </div>
            <span class="metric-val">@cpuLoad.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%</span>
        </div>
        <div class="metric-group">
            <span>Потоки</span>
            <span class="metric-val">@threadCount.ToString()</span>
        </div>
        <div class="metric-group">
            <span>Сессия</span>
            <span class="metric-val">@sessionTime</span>
        </div>
    </div>

    <!-- CRT Scanline Overlay -->
    <div class="scanlines"></div>
</div>

<script>
    window.scrollToBottom = (element) => {
        if (element) element.scrollTop = element.scrollHeight;
    };
</script>

<style>
    .cyber-console {
        position: fixed;
        top: 0px;
        right: 2px;
        width: 480px;
        background: #0a0f14;
        border: 1px solid #00ffcc44;
        border-radius: 6px;
        font-family: 'Consolas', 'Courier New', monospace;
        color: #00ffcc;
        overflow: hidden;
        box-shadow: 0 4px 20px #00ffcc11;
        z-index: 1000;
        backdrop-filter: blur(4px);
    }

    .console-header {
        background: #111820;
        padding: 5px 8px;
        font-size: 0.8rem;
        font-weight: bold;
        border-bottom: 1px solid #00ffcc33;
        display: flex;
        justify-content: space-between;
    }

    .badge-status {
        background: #00ffcc22;
        padding: 1px 5px;
        border-radius: 3px;
        font-size: 0.65rem;
    }

    .console-leds {
        display: flex;
        gap: 12px;
        padding: 4px 8px;
        background: #0d1217;
        border-bottom: 1px solid #00ffcc22;
    }

    .led-row {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 0.6rem;
        color: #ffffffaa;
    }

    .led-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        box-shadow: 0 0 4px currentColor;
    }

    .console-meta {
        display: flex;
        justify-content: space-between;
        padding: 3px 8px;
        font-size: 0.65rem;
        color: #00b8ff;
        background: #080b0e;
        border-bottom: 1px dashed #00ffcc22;
    }

    .console-logs {
        height: 120px;
        overflow-y: auto;
        padding: 5px;
        background: #05080a;
        scrollbar-width: thin;
        scrollbar-color: #00ffcc44 #05080a;
    }

    .log-line {
        font-size: 0.75rem;
        margin: 1px 0;
        white-space: pre-wrap;
        line-height: 1.3;
        opacity: 0.9;
    }

    .log-SYS {
        color: #00ffcc;
    }

    .log-NET {
        color: #ffcc00;
    }

    .log-DB {
        color: #00ff88;
    }

    .log-SEC {
        color: #cc88ff;
    }

    .log-ERR {
        color: #ff4444;
    }

    .cursor-blink {
        display: inline-block;
        font-size: 0.65em; /* 👈 Уменьшает курсор относительно текста логов */
        vertical-align: middle;
        animation: blink 1s step-end infinite;
    }
    @@keyframes blink {
        50% {
            opacity: 0;
        }
    }

    .console-metrics {
        display: flex;
        justify-content: space-between;
        padding: 4px 8px;
        font-size: 0.7rem;
        background: #0d1217;
        border-top: 1px solid #00ffcc33;
        gap: 4px;
    }

    .metric-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }

    .sparkline {
        display: flex;
        align-items: flex-end;
        height: 12px;
        gap: 1px;
        margin: 2px 0;
    }

    .spark-bar {
        width: 3px;
        background: linear-gradient(90deg, #00ffcc, #00b8ff);
        border-radius: 1px;
        transition: height 0.3s ease;
    }

    .metric-val {
        color: #ffffffcc;
    }

    .scanlines {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: repeating-linear-gradient( to bottom, transparent 0px, transparent 2px, rgba(0, 255, 204, 0.03) 2px, rgba(0, 255, 204, 0.03) 4px );
        pointer-events: none;
        z-index: 2;
    }
</style>

@code {
    private readonly List<LogEntry> logs = new List<LogEntry>();
    private readonly List<double> cpuHistory = new List<double>();
    private ElementReference logScrollContainer;
    private bool _needsScroll;
    private double cpuLoad = 0.0;
    private int threadCount = 0;
    private string sessionTime = "00:00:00";
    private DateTime sessionStart = DateTime.UtcNow;
    private string statusText = "ONLINE";
    private string sessionId = string.Empty;
    private string netLedColor = "#00ffcc";
    private string cpuLedColor = "#00ffcc";
    private PeriodicTimer? updateTimer;
    private CancellationTokenSource? cts;
    private int logCounter = 0;

    protected override void OnInitialized()
    {
        sessionId = GenerateSessionHash();
        cts = new CancellationTokenSource();
        updateTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = RunUpdateLoopAsync(cts.Token);
        AddSystemLog("[SYS] Инициализация модуля мониторинга... OK");
        AddSystemLog("[CFG] Загрузка директив из ядра конфигурации... 4 параметра");
        AddSystemLog("[SEC] Проверка целостности соединения... PASS");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsScroll)
        {
            await JS.InvokeVoidAsync("scrollToBottom", logScrollContainer);
            _needsScroll = false;
        }
    }

    private async Task RunUpdateLoopAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && await updateTimer!.WaitForNextTickAsync(token))
            {
                UpdateMetrics();
                GenerateAtmosphericLog();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Нормальное завершение
        }
    }

    private void UpdateMetrics()
    {
        System.Diagnostics.Process currentProcess = System.Diagnostics.Process.GetCurrentProcess();
        double cpuTimeMs = currentProcess.TotalProcessorTime.TotalMilliseconds;
        double elapsedMs = (DateTime.UtcNow - sessionStart).TotalMilliseconds;

        if (elapsedMs > 0)
        {
            double roughLoad = (cpuTimeMs / elapsedMs) * 100.0;
            cpuLoad = Math.Min(100.0, Math.Max(0.0, roughLoad * 1.5));
        }

        // Обновляем историю для sparkline
        cpuHistory.Add(cpuLoad);
        if (cpuHistory.Count > 20)
        {
            cpuHistory.RemoveAt(0);
        }

        // LED логика (симуляция порогов)
        netLedColor = cpuLoad > 60 ? "#ff4444" : cpuLoad > 30 ? "#ffcc00" : "#00ffcc";
        cpuLedColor = cpuLoad > 75 ? "#ff4444" : cpuLoad > 40 ? "#ffcc00" : "#00ffcc";

        threadCount = currentProcess.Threads.Count;
        TimeSpan elapsed = DateTime.UtcNow - sessionStart;
        sessionTime = elapsed.ToString("hh\\:mm\\:ss");
    }

    private void GenerateAtmosphericLog()
    {
        logCounter++;
        string timestamp = DateTime.Now.ToString("HH:mm:ss");
        string message = string.Empty;

        if (logCounter % 12 == 0) message = $"[{timestamp}] [DB] Синхронизация индексов... PASS";
        else if (logCounter % 19 == 0) message = $"[{timestamp}] [NET] Пинг шлюза RSS... {new Random().Next(110, 280)} мс";
        else if (logCounter % 25 == 0) message = $"[{timestamp}] [SEC] Верификация токена... OK";
        else if (logCounter % 33 == 0) message = $"[{timestamp}] [MEM] Сборка мусора... {new Random().Next(1, 5)} мс";
        else if (logCounter % 40 == 0) message = $"[{timestamp}] [CORE] Ожидание следующего цикла...";
        else return;

        AddSystemLog(message);
    }

    private void AddSystemLog(string message)
    {
        string level = "SYS";
        if (message.Contains("[NET]")) level = "NET";
        else if (message.Contains("[DB]")) level = "DB";
        else if (message.Contains("[SEC]")) level = "SEC";
        else if (message.Contains("[ERR]")) level = "ERR";

        logs.Add(new LogEntry { Text = message, Level = level });
        _needsScroll = true;

        if (logs.Count > 100)
        {
            logs.RemoveRange(0, 40);
        }
    }

    private static string GenerateSessionHash()
    {
        byte[] bytes = new byte[16];
        new Random().NextBytes(bytes);
        return BitConverter.ToString(bytes).Replace("-", string.Empty).Substring(0, 8);
    }

    public void Dispose()
    {
        cts?.Cancel();
        updateTimer?.Dispose();
        cts?.Dispose();
    }

    private class LogEntry
    {
        public string Text { get; set; } = string.Empty;
        public string Level { get; set; } = string.Empty;
    }
}