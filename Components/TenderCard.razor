@using QwenWeb.Models
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager

<div class="card mb-3 shadow-sm" style="cursor: pointer; transition: transform 0.1s;" @onclick="OpenDetails">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-title mb-0 fw-bold text-truncate" style="max-width: 75%;">
                @Item.ParsedInfo.ObjectName
            </h6>
            <div class="d-flex gap-2 flex-shrink-0">
                @if (!string.IsNullOrEmpty(Item.ParsedInfo.LawType))
                {
                    <span class="badge bg-primary">@Item.ParsedInfo.LawType</span>
                }
                @if (!string.IsNullOrEmpty(Item.ParsedInfo.Stage))
                {
                    <span class="badge @(GetStageBadgeClass(Item.ParsedInfo.Stage))">@Item.ParsedInfo.Stage</span>
                }
            </div>
        </div>

        <div class="row text-muted small mb-2">
            <div class="col-12 col-md-8 mb-1">
                🏢 <span class="text-dark">@Item.ParsedInfo.Customer</span>
            </div>
            @if (Item.ParsedInfo.InitialPrice.HasValue)
            {
                <div class="col-12 col-md-4 text-md-end fw-bold text-success">
                    💰 @Item.ParsedInfo.InitialPrice.Value.ToString("N2", System.Globalization.CultureInfo.CurrentCulture) @Item.ParsedInfo.Currency
                </div>
            }
        </div>

        <div class="text-muted small border-top pt-2 mt-2">
            📅 @(Item.Record.PubDate?.ToString("dd.MM.yyyy HH:mm") ?? "Дата не указана")
        </div>
    </div>
</div>

@code {
    [Parameter] public required QwenWeb.Models.TenderDisplayItem Item { get; set; }

    private string GetStageBadgeClass(string stage)
    {
        if (string.IsNullOrEmpty(stage)) return "bg-secondary";
        return stage.Contains("Подача", System.StringComparison.OrdinalIgnoreCase) ? "bg-success" :
               stage.Contains("Завершена", System.StringComparison.OrdinalIgnoreCase) ? "bg-secondary" :
               stage.Contains("Отменена", System.StringComparison.OrdinalIgnoreCase) ? "bg-danger" : "bg-info";
    }

    private void OpenDetails()
    {
        string encodedLink = System.Uri.EscapeDataString(Item.Record.Link);
        NavigationManager.NavigateTo($"/tender?link={encodedLink}");
    }
}