@using QwenWeb.Models
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager

@code {
    [Parameter] public TenderDisplayItem Item { get; set; } = default!;
}

<div class="card mb-3 shadow-sm tender-card" @onclick="OpenDetails" style="cursor: pointer;">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-title mb-0 fw-bold text-truncate tender-card-title" style="max-width: 70%;">
                @* 🔹 безопасное получение названия *@
                @(Item?.ParsedInfo?.ObjectName ?? Item?.Record?.Title ?? "Без названия")
            </h6>
            <div class="d-flex gap-2 flex-shrink-0">
                @* 🔹 закон (если есть) *@
                @if (!string.IsNullOrEmpty(Item?.ParsedInfo?.LawType))
                {
                    <span class="badge bg-primary">@Item.ParsedInfo.LawType</span>
                }
                @* 🔹 цена из записи (не из ParsedInfo) *@
                @if (Item?.Record?.InitialPrice.HasValue == true)
                {
                    <span class="badge bg-success">@(((decimal)Item.Record.InitialPrice).ToString("N0")) ₽</span>
                }
            </div>
        </div>

        <div class="text-muted small mb-2">
            @* 🔹 только безопасные поля из Record *@
            @if (!string.IsNullOrEmpty(Item?.Record?.RegionCode))
            {
                <span>📍 @Item.Record.RegionCode</span>
                <span class="mx-1">•</span>
            }
            @* заказчик пока не отображаем, пока не знаем точные свойства в ParsedInfo *@
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @* 🔹 дата публикации *@
                @if (Item?.Record?.PubDate.HasValue == true)
                {
                    <span>📅 @Item.Record.PubDate?.ToString("dd.MM.yyyy")</span>
                }
                @* 🔹 номер закупки *@
                @if (!string.IsNullOrEmpty(Item?.Record?.RegNumber))
                {
                    <span class="mx-2">•</span>
                    <code>@Item.Record.RegNumber</code>
                }
            </small>
            @* 🔹 статус обработки *@
            @if (Item?.Record?.Status == "raw")
            {
                <span class="badge bg-warning text-dark">⏳ обработка</span>
            }
            else if (Item?.Record?.Status == "processed")
            {
                <span class="badge bg-success">✓ готово</span>
            }
            else if (Item?.Record?.Status == "error")
            {
                <span class="badge bg-danger">⚠ ошибка</span>
            }
        </div>
    </div>
</div>

@code {
    private void OpenDetails()
    {
        if (Item?.Record?.Id > 0)
        {
            NavigationManager.NavigateTo($"/monitor/tenders/{Item.Record.Id}");
        }
    }
}