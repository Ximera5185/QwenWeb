@page "/tenders"
@rendermode InteractiveServer
@using System.Net.Http
@inject HttpClient Http

<h3>📜 Лента госзакупок (RSS)</h3>

@if (IsLoading)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Загрузка данных...</p>
    </div>
}
else if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">❌ @ErrorMessage</div>
    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadFeed">🔄 Попробовать снова</button>
}
else if (Items?.Any() == true)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="text-muted">Найдено: @Items.Count записей</span>
        <button class="btn btn-outline-primary btn-sm" @onclick="LoadFeed">🔄 Обновить</button>
    </div>

    <div class="list-group">
        @foreach (var item in Items)
        {
            <a href="@item.Link" target="_blank" rel="noopener" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h6 class="mb-1">@item.Title</h6>
                    <small class="text-muted">@item.PubDate?.ToString("dd.MM.yyyy HH:mm")</small>
                </div>
                <p class="mb-1 text-secondary description-text">
                    @((MarkupString)item.Description)
                </p>
            </a>
        }
    </div>
}
else
{
    <div class="alert alert-info">📭 Лента пуста или не удалось получить данные.</div>
}

@code {
    public List<RssItem> Items { get; set; } = new();
    public bool IsLoading { get; set; }
    public string ErrorMessage { get; set; } = string.Empty;

    // 👇 Ссылка на RSS госзакупок
    private const string RssUrl = "https://zakupki.gov.ru/epz/order/extendedsearch/rss.html";

    protected override async Task OnInitializedAsync()
    {
        await LoadFeed();
    }

    public async Task LoadFeed()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        Items.Clear();
        StateHasChanged();

        try
        {
            // 1. Создаём запрос с заголовками браузера (обход защиты 403)
            using var request = new HttpRequestMessage(HttpMethod.Get, RssUrl);
            request.Headers.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36");
            request.Headers.Add("Accept", "application/rss+xml, application/xml, text/xml, */*");

            // 2. Отправляем запрос
            using var response = await Http.SendAsync(request);

            if (!response.IsSuccessStatusCode)
            {
                throw new Exception($"Сервер вернул ошибку: {(int)response.StatusCode} {(response.ReasonPhrase)}");
            }

            // 3. Парсим XML
            var xml = await response.Content.ReadAsStringAsync();
            var doc = System.Xml.Linq.XDocument.Parse(xml);

            var channel = doc.Root?.Element("channel");
            if (channel != null)
            {
                Items = channel.Elements("item")
                               .Select(i => new RssItem
                               {
                                   Title = i.Element("title")?.Value ?? "Без названия",
                                   Link = i.Element("link")?.Value ?? "#",
                                   Description = i.Element("description")?.Value ?? "",
                                   PubDate = DateTime.TryParse(i.Element("pubDate")?.Value, out var dt) ? dt : null
                               })
                               .ToList();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Ошибка: {ex.Message}. Попробуйте позже или проверьте доступность портала.";
            // Демо-данные на случай блокировки
            Items = new List<RssItem>
            {
                new() { Title = "Демо-закупка #1", Link = "#", Description = "Портал вернул 403. Заголовки добавлены, попробуйте обновить.", PubDate = DateTime.Now },
                new() { Title = "Демо-закупка #2", Link = "#", Description = "Если ошибка persists, возможно, требуется прокси или токен.", PubDate = DateTime.Now.AddHours(-2) }
            };
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    public class RssItem
    {
        public string Title { get; set; } = "";
        public string Link { get; set; } = "";
        public string Description { get; set; } = "";
        public DateTime? PubDate { get; set; }
    }
}