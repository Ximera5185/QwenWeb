@page "/tenderplan"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Options
@using QwenWeb.Configuration
@using QwenWeb.Data
@using QwenWeb.Models
@using QwenWeb.Services.Tenderplan
@inject TenderplanDbContext TenderplanDb
@inject TenderplanBackgroundService TenderplanService
@inject IOptions<TenderplanSettings> TenderplanOptions
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@implements IDisposable

<h3>📊 Мониторинг закупок (Tenderplan API)</h3>

@if (!TenderplanOptions.Value.Enabled)
{
    <div class="alert alert-warning mb-4">
        ⚠️ <strong>Источник отключён:</strong> В настройках <code>Tenderplan:Enabled</code> установлено значение <code>false</code>.
        Фоновый опрос не запущен. Для активации измените значение в <code>appsettings.json</code> или UserSecrets и перезапустите приложение.
    </div>
}
else
{
    <div class="alert alert-success mb-4">
        🟢 <strong>Источник активен:</strong> Опрос Tenderplan API запущен (интервал: @TenderplanOptions.Value.PollIntervalMinutes мин).
    </div>
}

<div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <strong>Всего опросов:</strong> @TenderplanService.TotalPollsCount.ToString()<br />
        <strong>Последний запуск:</strong> @(TenderplanService.LastRunTimeUtc == DateTime.MinValue ? "Ещё не запускался" : TenderplanService.LastRunTimeUtc.ToString("dd.MM.yyyy HH:mm"))<br />
        <strong>Следующий опрос через:</strong> <span class="fw-bold text-primary">@countdownText</span><br />
        <strong>Найдено за раз:</strong> @(TenderplanService.IsErrorLastRun ? "<span class=\"text-danger\">Ошибка</span>" : (TenderplanService.NewTendersFoundLastRun == 0 ? "0 новых" : TenderplanService.NewTendersFoundLastRun.ToString() + " новых"))<br />
        <strong>Всего в базе:</strong> @totalCount.ToString()
    </div>
    <button class="btn btn-outline-primary" @onclick="RunManualCheckAsync" disabled="@(TenderplanService.LastRunTimeUtc > DateTime.UtcNow.AddMinutes(-1) || !TenderplanOptions.Value.Enabled)">
        🔄 Проверить сейчас
    </button>
</div>

@if (displayItems.Count == 0)
{
    <div class="text-center py-5 text-muted">
        @(TenderplanOptions.Value.Enabled ? "Загрузка данных из базы или ожидание первого цикла..." : "Источник отключён. Активируйте для получения данных.")
    </div>
}
else
{
    <div class="list-group">
        @foreach (TenderplanRecord item in displayItems)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title mb-0 fw-bold text-truncate">@item.Title</h6>
                        <span class="badge bg-info">TP</span>
                    </div>
                    <div class="row text-muted small mb-2">
                        <div class="col-12 col-md-8 mb-1">
                            🆔 <span class="text-dark">@(item.RegNumber ?? "Нет номера")</span>
                        </div>
                        @if (item.InitialPrice.HasValue)
                        {
                            <div class="col-12 col-md-4 text-md-end fw-bold text-success">
                                💰 @item.InitialPrice.Value.ToString("N2", System.Globalization.CultureInfo.CurrentCulture) @item.Currency
                            </div>
                        }
                    </div>
                    <div class="text-muted small border-top pt-2 mt-2">
                        📅 @(item.PublishDateUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "Дата не указана")
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    // 🔹 Private readonly fields
    private readonly List<TenderplanRecord> displayItems = new List<TenderplanRecord>();
    private PeriodicTimer? countdownTimer;
    private CancellationTokenSource? countdownCts;

    // 🔹 Private fields
    private int totalCount = 0;
    private string countdownText = "—";

    // 🔹 Public properties (state for UI)
    // (handled via private fields above for Blazor compatibility)

    // 🔹 Lifecycle overrides
    protected override void OnInitialized()
    {
        countdownCts = new CancellationTokenSource();
        countdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = UpdateCountdownLoop(countdownCts.Token);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadFromDatabaseAsync();
    }

    // 🔹 Public methods
    public async Task RunManualCheckAsync()
    {
        if (!TenderplanOptions.Value.Enabled) return;
        await TenderplanService.RunManualAsync();
        await LoadFromDatabaseAsync();
    }

    // 🔹 Private helpers
    private async Task UpdateCountdownLoop(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && await countdownTimer!.WaitForNextTickAsync(token))
            {
                UpdateCountdownText();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private void UpdateCountdownText()
    {
        if (TenderplanService.LastRunTimeUtc == DateTime.MinValue || !TenderplanOptions.Value.Enabled)
        {
            countdownText = TenderplanOptions.Value.Enabled ? "ожидание первого запуска..." : "источник отключён";
            return;
        }

        int intervalMinutes = TenderplanOptions.Value.PollIntervalMinutes;
        DateTime nextRun = TenderplanService.LastRunTimeUtc.AddMinutes(intervalMinutes);
        TimeSpan remaining = nextRun - DateTime.UtcNow;

        if (remaining.TotalSeconds <= 0)
        {
            countdownText = "запуск...";
        }
        else
        {
            int minutes = (int)remaining.TotalMinutes;
            int seconds = remaining.Seconds;
            countdownText = $"{minutes:D2}:{seconds:D2}";
        }
    }

    private async Task LoadFromDatabaseAsync()
    {
        try
        {
            List<TenderplanRecord> rawRecords = await TenderplanDb.TenderplanRecords
     .OrderByDescending(t => t.CreatedAtUtc)
     .Take(100)
     .ToListAsync();

            displayItems.Clear();
            displayItems.AddRange(rawRecords);
            totalCount = displayItems.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR] LoadTenderplanFromDatabaseAsync: {ex.Message}");
            displayItems.Clear();
            totalCount = 0;
        }
        finally
        {
            UpdateCountdownText();
            StateHasChanged();
        }
    }

    // 🔹 Dispose
    public void Dispose()
    {
        countdownCts?.Cancel();
        countdownTimer?.Dispose();
        countdownCts?.Dispose();
    }
}