@page "/tender"
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using System.Linq
@inject QwenWeb.Data.TenderMonitorDbContext Db
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager


@if (isLoading)
{
    <div class="d-flex justify-content-center align-items-center spinner-container">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (record == null)
{
    <div class="alert alert-warning mt-4">
        <h6 class="alert-heading">⚠️ Запись не найдена</h6>
        <p class="mb-0 small">Возможно, ссылка повреждена или закупка удалена.</p>
        <button class="btn btn-sm btn-outline-primary mt-2" @onclick="GoBack">← Назад</button>
    </div>
}
else
{
    <div class="container-fluid px-3 py-2">
        <button class="btn btn-sm btn-outline-secondary mb-2" @onclick="GoBack">
            ← Назад к списку
        </button>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold text-truncate tender-header-title">
                    @ParsedInfo.ObjectName
                </h5>
                <div class="d-flex gap-1">
                    @if (!string.IsNullOrEmpty(ParsedInfo.LawType))
                    {
                        <span class="badge bg-primary">@ParsedInfo.LawType</span>
                    }
                    @if (!string.IsNullOrEmpty(ParsedInfo.Stage))
                    {
                        <span class="badge @(GetStageBadgeClass(ParsedInfo.Stage))">@ParsedInfo.Stage</span>
                    }
                </div>
            </div>

            <div class="card-body py-2 px-3">
                <!-- Цена и заказчик -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mb-2 gap-2">
                    <div class="small text-muted">
                        🏢 <span class="text-dark">@ParsedInfo.Customer</span>
                    </div>
                    @if (ParsedInfo.InitialPrice.HasValue)
                    {
                        <div class="fw-bold text-success">
                            💰 @ParsedInfo.InitialPrice.Value.ToString("N2", System.Globalization.CultureInfo.CurrentCulture) @ParsedInfo.Currency
                        </div>
                    }
                </div>

                <!-- Даты и ссылка -->
                <div class="row small text-muted mb-2">
                    <div class="col-auto">📅 @FormatDate(record.PubDate)</div>
                    <div class="col-auto">🔄 @FormatDateUtc(record.CreatedAtUtc)</div>
                    <div class="col-12 text-break link-text-xs">🔗 @record.Link</div>
                </div>

                <!-- Описание из RSS -->
                <div class="mt-3">
                    <h6 class="mb-2 small text-muted">📜 Полное описание (из RSS)</h6>
                    <div class="p-3 bg-light rounded small tender-rss-content rss-description">
                        @((MarkupString)(ParsedInfo.RawDescription ?? string.Empty))
                    </div>
                </div>

                <!-- 📎 Документация закупки (Этапы 3-5) -->
                <div class="mt-4 p-3 border rounded bg-light">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 fw-bold">📎 Документация закупки</h6>
                        @if (documentListState == DocumentListState.Idle)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="LoadDocumentListAsync" disabled="@(isLoading || record == null)">
                                🔍 Загрузить список
                            </button>
                        }
                        else if (documentListState == DocumentListState.Loading)
                        {
                            <span class="spinner-border spinner-border-sm text-primary" role="status"></span>
                        }
                        else if (documentListState == DocumentListState.Ready)
                        {
                            <span class="badge bg-success">@documents.Count документов</span>
                        }
                    </div>

                    @if (documentListState == DocumentListState.Error)
                    {
                        <div class="alert alert-warning small mb-0">
                            ⚠️ @documentListError
                            <button class="btn btn-link p-0 ms-2" @onclick="LoadDocumentListAsync">Повторить</button>
                        </div>
                    }
                    else if (documentListState == DocumentListState.Ready && documents.Count > 0)
                    {
                        <div class="table-responsive small">
                            <table class="table table-sm table-borderless mb-0">
                                <thead class="text-muted">
                                    <tr>
                                        <th class="col-checkbox"></th>
                                        <th class="col-filename">Файл</th>
                                        <th>ID</th>
                                        <th>Тип</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (QwenWeb.Models.EisDocumentItem doc in documents)
                                    {
                                        <tr class="@(selectedDocuments.Contains(doc) ? "table-primary" : "")">
                                            <td class="text-center">
                                                @if (doc.Status != "downloaded")
                                                {
                                                    <input type="checkbox"
                                                           class="form-check-input"
                                                           @onchange="@(e => ToggleDocumentSelection(doc))"
                                                           disabled="@(isDownloading || doc.Status == "error")" />
                                                }
                                            </td>
                                            <td class="text-break">
                                                @if (doc.IsArchive)
                                                {
                                                    <span class="me-1">📦</span>
                                                }
                                                @doc.FileName
                                                @if (!string.IsNullOrEmpty(doc.LocalPath))
                                                {
                                                    <br /><small class="text-success">✓ Локально: @Path.GetFileName(doc.LocalPath)</small>
                                                }
                                                @if (!string.IsNullOrEmpty(doc.ExtractedTextPath))
                                                {
                                                    <br /><small class="text-info">📄 Текст извлечён</small>
                                                }
                                            </td>
                                            <td class="text-muted text-xs">@doc.FileId</td>
                                            <td>
                                                @if (doc.MimeType == "application/pdf")
                                                {
                                                    <span class="badge bg-danger">PDF</span>
                                                }
                                                else if (doc.MimeType?.Contains("word") == true)
                                                {

                                                    <span class="badge bg-primary">DOCX</span>
                                                }
                                                else if (doc.MimeType?.Contains("excel") == true)
                                                {

                                                    <span class="badge bg-success">XLSX</span>
                                                }
                                                else if (doc.IsArchive)
                                                {

                                                    <span class="badge bg-secondary">ARCH</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-light text-dark border">FILE</span>
                                                }
                                            </td>
                                            <td class="col-status">
                                                @if (doc.Status == "downloading")
                                                {
                                                    <div class="progress progress-thin">
                                                        <div class="progress-bar" style="width: @(doc.DownloadProgress * 100)%"></div>
                                                    </div>
                                                    <small class="text-muted">@((doc.DownloadProgress * 100).ToString("F0"))%</small>
                                                }
                                                else if (doc.Status == "downloaded")
                                                {
                                                    <span class="badge bg-success">✓ Скачан</span>
                                                }
                                                else if (doc.Status == "error")
                                                {
                                                    <span class="badge bg-danger" title="@doc.ErrorMessage">✗</span>
                                                }
                                                else
                                                {
                                                    <a href="@doc.DownloadUrl" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">↗</a>
                                                }
                                                <!-- Индикатор извлечения текста -->
                                                @if (doc.TextExtractionStatus == "extracting")
                                                {
                                                    <div class="progress mt-1 progress-ultra-thin">
                                                    <div class="progress-bar bg-success" style="width: @(doc.TextExtractionProgress * 100)%"></div></div>
                                                }
                                                else if (doc.TextExtractionStatus == "extracted")
                                                {
                                                    <br /><small class="text-success">📄 @(doc.ExtractedText?.Length.ToString("N0")) симв.</small>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Кнопки действий (Этапы 4 и 5) -->
                        <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top flex-wrap gap-2">
                            <small class="text-muted">
                                Выбрано: @selectedDocuments.Count из @documents.Count
                                @if (!string.IsNullOrEmpty(downloadError))
                                {
                                    <span class="text-danger ms-2">⚠️ @downloadError</span>
                                }
                                @if (!string.IsNullOrEmpty(textExtractionError))
                                {
                                    <span class="text-danger ms-2">⚠️ @textExtractionError</span>
                                }
                            </small>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-primary"
                                        @onclick="StartDownloadAsync"
                                        disabled="@(isDownloading || selectedDocuments.Count == 0)">
                                    @if (isDownloading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Скачивание...</span>
                                    }
                                    else
                                    {
                                        <span>📥 Скачать (@selectedDocuments.Count)</span>
                                    }
                                </button>

                                <button class="btn btn-sm btn-success"
                                        @onclick="StartTextExtractionAsync"
                                        disabled="@(isExtractingText || documentListState != DocumentListState.Ready || documents.Count == 0)">
                                    @if (isExtractingText)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        <span>Извлечение...</span>
                                    }
                                    else
                                    {
                                        <span> Извлечь текст</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                    else if (documentListState == DocumentListState.Idle && record != null)
                    {
                        <p class="text-muted small mb-0">Нажмите «Загрузить список», чтобы получить документы с ЕИС.</p>
                    }
                </div>

                <!-- 🤖 AI-Аналитика документов (ПОЛНЫЙ БЛОК) -->
                <div class="mt-4 p-3 border rounded bg-light">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 fw-bold">🤖 AI-Аналитика</h6>
                        @if (IsAiLoading)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="CancelAiRequest">
                                ⏹ Стоп
                            </button>
                        }
                    </div>

                    <!-- Шаблоны быстрых промтов -->
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">📋 Быстрые вопросы:</small>
                        <div class="d-flex flex-wrap gap-1">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptGoodsQty)">📦 Товары и объёмы</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptDeliveryTerms)">🚚 Поставка</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptQualityReqs)">✅ Качество</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptRisksPenalties)">⚠️ Риски</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptPaymentTerms)">💰 Оплата</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptKeyDates)">📅 Сроки</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptEvaluationCriteria)">⚖️ Критерии</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SetPrompt(PromptExperienceReqs)">🎓 Опыт</button>
                            <button type="button" class="btn btn-sm btn-outline-info" @onclick="() => SetPrompt(PromptSummary)">📝 Резюме</button>
                        </div>
                    </div>

                    <!-- Поле ввода промта -->
                    <textarea class="form-control mb-2"
                              rows="3"
                              placeholder="Например: Выдели ключевые требования к поставщику..."
                              @bind="AiPrompt"
                              disabled="@(IsAiLoading)">
    </textarea>

                    <!-- Кнопка отправки -->
                    <button class="btn btn-primary btn-sm mb-3"
                            @onclick="SendToAiAsync"
                            disabled="@(IsAiLoading || string.IsNullOrWhiteSpace(AiPrompt))">
                        @if (IsAiLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Думаю...</span>
                        }
                        else
                        {
                            <span>🔍 Проанализировать</span>
                        }
                    </button>

                    <!-- Область ответа -->
                    @if (!string.IsNullOrEmpty(AiResponse) || IsAiLoading)
                    {
                        <div class="p-3 bg-white border rounded small ai-response ai-response-box">

                            @if (IsAiLoading && string.IsNullOrEmpty(AiResponse))
                            {
                                <span class="text-muted">🔄 Подключение к ИИ...</span>
                            }
                            else if (IsAiLoading)
                            {
                                @AiResponse
                                <span class="cursor-blink">▋</span>
                            }
                            else
                            {
                                @AiResponse
                            }
                        </div>
                    }

                    <!-- Подсказка, если нет текста -->
                    @if (documents.Count > 0 && documents.All(d => string.IsNullOrEmpty(d.ExtractedText)))
                    {
                        <small class="text-muted d-block mt-2">
                            💡 Сначала нажмите «Извлечь текст», чтобы ИИ мог проанализировать документы.
                        </small>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    // 👇 Тексты для быстрых промтов (вынесены, чтобы не ломать парсер Razor)
    private const string PromptRequirements = "Выдели ключевые требования к поставщику и условия участия в закупке.";
    private const string PromptDeadlines = "Какие сроки поставки, исполнения контракта и штрафные санкции указаны?";
    private const string PromptRisks = "Есть ли в документации риски для поставщика? Выдели спорные моменты.";
    private const string PromptGoodsQty = "Какие именно товары и в каком количестве необходимо поставить? Укажи номенклатуру, артикулы, ГОСТы/ТУ, классификаторы (ОКПД2) и единицы измерения.";
    private const string PromptDeliveryTerms = "Каковы условия, сроки и место поставки? Включи график поставок, требования к упаковке, маркировке, транспортной таре и порядок приёмки.";
    private const string PromptQualityReqs = "Какие требования к качеству товаров? Укажи необходимые сертификаты, декларации соответствия, гарантии, сроки годности и порядок замены бракованного товара.";
    private const string PromptRisksPenalties = "Проанализируй документацию на скрытые риски, неочевидные штрафы, пени, неустойки, односторонние условия для поставщика и требования к форс-мажору.";
    private const string PromptPaymentTerms = "Каковы финансовые условия контракта? Укажи размер аванса, график платежей, сроки оплаты после подписания актов, требования к обеспечению исполнения и банковской гарантии.";
    private const string PromptKeyDates = "Выдели все важные сроки: дата окончания подачи заявок, разъяснения, вскрытие конвертов, заключение контракта, этапы исполнения, гарантия.";
    private const string PromptEvaluationCriteria = "По каким критериям будет оцениваться заявка? Укажи вес ценового и неценового критерия, требования к опыту, квалификации, лицензиям/СРО и дополнительные баллы.";
    private const string PromptSummary = "Составь краткое резюме тендера: предмет закупки, начальная цена, ключевые сроки, главные требования к поставщику и основные риски. Ответь структурированно.";
    private const string PromptExperienceReqs = "Какие требования к опыту участника закупки указаны? Укажи необходимость наличия аналогичных исполненных контрактов, требования к СРО, лицензиям, допускам, квалификационным требованиям к персоналу и материально-технической базе.";

    private QwenWeb.Models.TenderMonitorRecord? record;
    private QwenWeb.Models.ParsedTenderInfo ParsedInfo = new();
    private bool isLoading = true;

    [Inject] public QwenWeb.Services.Documents.EisDocumentService DocumentService { get; set; } = null!;
    private List<QwenWeb.Models.EisDocumentItem> documents = new();
    private DocumentListState documentListState = DocumentListState.Idle;
    private string? documentListError;
    private enum DocumentListState { Idle, Loading, Ready, Error }

    private List<QwenWeb.Models.EisDocumentItem> selectedDocuments = new();
    private bool isDownloading = false;
    private string? downloadError;
    private readonly Progress<QwenWeb.Models.EisDocumentItem> downloadProgress = new();

    private bool isExtractingText = false;
    private string? textExtractionError;
    private readonly Progress<QwenWeb.Models.EisDocumentItem> textExtractionProgress = new();
    private int totalExtractedChars = 0;

    // 👇 AI-Аналитика (Шаг 2)
    [Inject] public IConfiguration Config { get; set; } = null!;
    private string AiPrompt { get; set; } = string.Empty;
    private string AiResponse { get; set; } = string.Empty;
    private bool IsAiLoading { get; set; }
    private bool IsAiStreaming { get; set; }
    private System.Threading.CancellationTokenSource? _aiCts;

    protected override void OnInitialized()
    {
        downloadProgress.ProgressChanged += (s, d) => StateHasChanged();
        textExtractionProgress.ProgressChanged += (s, d) =>
        {
            totalExtractedChars = documents.Sum(x => x.ExtractedText?.Length ?? 0);
            StateHasChanged();
        };
    }

    protected override async Task OnInitializedAsync()
    {
        string currentUri = NavigationManager.Uri;
        var uri = new System.Uri(currentUri);
        string? linkQuery = System.Web.HttpUtility.ParseQueryString(uri.Query)["link"];

        if (!string.IsNullOrEmpty(linkQuery))
        {
            string decodedLink = System.Uri.UnescapeDataString(linkQuery);
            record = await Db.Tenders.FirstOrDefaultAsync(t => t.Link == decodedLink);
            if (record != null)
            {
                ParsedInfo = QwenWeb.Services.Parsing.TenderInfoParser.Parse(record.Description);
            }
        }
        isLoading = false;
    }

    private async Task LoadDocumentListAsync()
    {
        if (record == null || string.IsNullOrEmpty(record.Link)) { documentListError = "Нет ссылки на закупку"; documentListState = DocumentListState.Error; StateHasChanged(); return; }
        documentListState = DocumentListState.Loading; documentListError = null; StateHasChanged();
        try { documents = await DocumentService.GetDocumentListAsync(record.Link); documentListState = documents.Count > 0 ? DocumentListState.Ready : DocumentListState.Idle; }
        catch (Exception ex) { documentListError = ex.Message; documentListState = DocumentListState.Error; }
        StateHasChanged();
    }

    private async Task StartDownloadAsync()
    {
        if (record == null || selectedDocuments.Count == 0) { downloadError = "Не выбраны файлы"; StateHasChanged(); return; }
        isDownloading = true; downloadError = null; StateHasChanged();
        try
        {
            string? regNumber = ExtractRegNumber(record.Link);
            if (string.IsNullOrEmpty(regNumber)) { downloadError = "Не удалось определить номер закупки"; isDownloading = false; StateHasChanged(); return; }
            var results = await DocumentService.DownloadFilesAsync(regNumber, selectedDocuments, downloadProgress, procurementUrl: record?.Link);
            for (int i = 0; i < documents.Count; i++)
            {
                var r = results.FirstOrDefault(x => x.FileId == documents[i].FileId);
                if (r != null) { documents[i].Status = r.Status; documents[i].LocalPath = r.LocalPath; documents[i].ErrorMessage = r.ErrorMessage; }
            }
        }
        catch (Exception ex) { downloadError = $"Ошибка: {ex.Message}"; }
        finally { isDownloading = false; StateHasChanged(); }
    }

    private async Task StartTextExtractionAsync()
    {
        if (record == null || documents.Count == 0) { textExtractionError = "Нет документов"; StateHasChanged(); return; }
        isExtractingText = true; textExtractionError = null; totalExtractedChars = 0; StateHasChanged();
        try
        {
            string? regNumber = ExtractRegNumber(record.Link);
            if (string.IsNullOrEmpty(regNumber)) { textExtractionError = "Не удалось определить номер закупки"; isExtractingText = false; StateHasChanged(); return; }
            var results = await DocumentService.ExtractTextFromDocumentsAsync(regNumber, documents, textExtractionProgress);
            for (int i = 0; i < documents.Count; i++)
            {
                var r = results.FirstOrDefault(x => x.FileId == documents[i].FileId);
                if (r != null) { documents[i].ExtractedText = r.ExtractedText; documents[i].ExtractedTextPath = r.ExtractedTextPath; documents[i].TextExtractionStatus = r.TextExtractionStatus; documents[i].TextExtractionError = r.TextExtractionError; }
            }
        }
        catch (Exception ex) { textExtractionError = $"Ошибка: {ex.Message}"; }
        finally { isExtractingText = false; StateHasChanged(); }
    }

    // 👇 AI Логика
    private async Task SendToAiAsync()
    {
        if (IsAiLoading || string.IsNullOrWhiteSpace(AiPrompt)) return;

        // 1. Собираем тексты документов
        var docsText = documents.Where(d => !string.IsNullOrEmpty(d.ExtractedText))
                                .Select(d => $"📄 {d.FileName}:\n{d.ExtractedText}")
                                .ToList();

        if (docsText.Count == 0)
        {
            AiResponse = "⚠️ Нет извлечённого текста. Сначала нажмите «Извлечь текст».";
            StateHasChanged();
            return;
        }

        // 2. Сброс и подготовка
        AiResponse = string.Empty;
        IsAiLoading = true;
        _aiCts?.Cancel();
        _aiCts = new System.Threading.CancellationTokenSource();
        var token = _aiCts.Token;
        StateHasChanged();

        try
        {
            // 3. Настройки API
            string? apiKey = Config["Qwen:ApiKey"];
            string? endpoint = Config["Qwen:Endpoint"];
            string? model = Config["Qwen:Model"];

            if (string.IsNullOrEmpty(apiKey) || string.IsNullOrEmpty(endpoint))
            {
                AiResponse = "❌ Не настроены API ключ или адрес в appsettings.json";
                IsAiLoading = false;
                StateHasChanged();
                return;
            }

            // 4. Формируем контекст
            var tenderInfo = $"🔍 ТЕНДЕР: {ParsedInfo.ObjectName}\n" +
                             $"🏢 Заказчик: {ParsedInfo.Customer}\n" +
                             $"💰 Цена: {(ParsedInfo.InitialPrice.HasValue ? $"{ParsedInfo.InitialPrice.Value:N2} {ParsedInfo.Currency}" : "не указана")}\n" +
                             $"⚖️ Закон: {ParsedInfo.LawType}\n";

            var fullContext = tenderInfo + "\n📎 ДОКУМЕНТЫ:\n" + string.Join("\n\n---\n\n", docsText);

            // 5. Запрос
            using var handler = new System.Net.Http.HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = System.Net.Http.HttpClientHandler.DangerousAcceptAnyServerCertificateValidator
            };
            using var client = new System.Net.Http.HttpClient(handler);
            client.Timeout = TimeSpan.FromMinutes(5);
            client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", apiKey);

            var payload = new
            {
                model = model,
                messages = new[] {
                    new { role = "system", content = "Ты эксперт по госзакупкам. Анализируй документы и отвечай кратко, по делу, на русском." },
                    new { role = "user", content = $"Контекст:\n{fullContext}\n\nВопрос:\n{AiPrompt}" }
                },
                stream = true,
                temperature = 0.3
            };

            var json = System.Text.Json.JsonSerializer.Serialize(payload);
            using var content = new System.Net.Http.StringContent(json, System.Text.Encoding.UTF8, "application/json");

            // 6. Отправка и чтение потока
            using var response = await client.PostAsync(endpoint, content, token);
            response.EnsureSuccessStatusCode();

            using var stream = await response.Content.ReadAsStreamAsync(token);
            using var reader = new System.IO.StreamReader(stream);
            var buffer = new System.Text.StringBuilder();

            // Цикл чтения (с поддержкой отмены)
            while (!reader.EndOfStream && !token.IsCancellationRequested && IsAiLoading)
            {
                var line = await reader.ReadLineAsync(token);
                if (string.IsNullOrWhiteSpace(line) || line.StartsWith(":")) continue;
                var trimmed = line.TrimStart();
                if (!trimmed.StartsWith("data:")) continue; // Внимание: тут может быть "data: " с пробелом, проверяем Trim

                var data = trimmed.Substring("data:".Length).Trim(); // Теперь реально удаляем "data:"
                if (data == "[DONE]") break;

                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(data);
                    var root = doc.RootElement;
                    if (root.TryGetProperty("choices", out var choices) && choices.GetArrayLength() > 0)
                    {
                        var delta = choices[0].GetProperty("delta");
                        if (delta.TryGetProperty("content", out var c) && c.ValueKind == System.Text.Json.JsonValueKind.String)
                        {
                            var tokenText = c.GetString();
                            if (!string.IsNullOrEmpty(tokenText))
                            {
                                buffer.Append(tokenText);
                                AiResponse = buffer.ToString();
                                await InvokeAsync(StateHasChanged);
                            }
                        }
                    }
                }
                catch { }
            }
        }
        catch (System.Threading.Tasks.TaskCanceledException)
        {
            AiResponse += "\n\n⚠️ Генерация остановлена.";
        }
        catch (Exception ex)
        {
            AiResponse = $"❌ Ошибка: {ex.Message}";
        }
        finally
        {
            IsAiLoading = false;
            StateHasChanged();
        }
    }

    private void FinishAiRequest()
    {
        IsAiLoading = false;
        IsAiStreaming = false;
        StateHasChanged();
    }

    private void CancelAiRequest()
    {
        _aiCts?.Cancel();
    }

    private static string? ExtractRegNumber(string? link)
    {
        if (string.IsNullOrEmpty(link)) return null;
        int index = link.IndexOf("regNumber=", StringComparison.OrdinalIgnoreCase);
        if (index == -1) return null;
        index += "regNumber=".Length;
        int endIndex = link.IndexOf('&', index);
        if (endIndex == -1) endIndex = link.Length;
        return link.Substring(index, endIndex - index);
    }

    private void ToggleDocumentSelection(QwenWeb.Models.EisDocumentItem doc)
    {
        if (selectedDocuments.Contains(doc)) selectedDocuments.Remove(doc);
        else selectedDocuments.Add(doc);
        StateHasChanged();
    }

    private string FormatDate(DateTime? dt) => dt?.ToString("dd.MM.yyyy HH:mm", System.Globalization.CultureInfo.CurrentCulture) ?? "Нет данных";
    private string FormatDateUtc(DateTime? dt) => dt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm", System.Globalization.CultureInfo.CurrentCulture) ?? "Нет данных";
    private string GetStageBadgeClass(string stage) => string.IsNullOrEmpty(stage) ? "bg-secondary" : stage.Contains("Подача", StringComparison.OrdinalIgnoreCase) ? "bg-success" : stage.Contains("Завершена", StringComparison.OrdinalIgnoreCase) ? "bg-secondary" : stage.Contains("Отменена", StringComparison.OrdinalIgnoreCase) ? "bg-danger" : "bg-info";
    private void GoBack() => NavigationManager.NavigateTo("/monitor");

    // 👇 Вспомогательный метод для шаблонов промтов
    private void SetPrompt(string template)
    {
        AiPrompt = template;
        StateHasChanged();
    }

    public void Dispose()
    {
        _aiCts?.Cancel();
        _aiCts?.Dispose();
    }
