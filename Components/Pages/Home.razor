@page "/"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IConfiguration Config

@using System.Text
@using System.Text.Json
@using System.Net.Http
@using System.Net.Http.Headers
@using System.IO

<h3>🤖 Qwen Chat</h3>

<!-- Область сообщений -->
<div class="chat-container">

    <!-- История сообщений -->
    @foreach (var msg in history.Where(m => m.Role != "system"))
    {
        <div class="message @(msg.Role == "user" ? "user" : "assistant")">
            <strong>@(msg.Role == "user" ? "👤 Вы:" : "🤖 Qwen:")</strong>
            <pre>@msg.Content</pre>
        </div>
    }

    <!-- Индикатор загрузки -->
    @if (isGenerating && string.IsNullOrEmpty(streamBuffer))
    {
        <div class="message thinking">
            <strong>🤖 Qwen:</strong>
            <pre><em>🔄 Думаю<span class="dots"></span></em></pre>
        </div>
    }

    <!-- Стриминг ответа -->
    @if (isGenerating && !string.IsNullOrEmpty(streamBuffer))
    {
        <div class="message streaming">
            <strong>🤖 Qwen:</strong>
            <pre>@streamBuffer<span class="cursor">|</span></pre>
        </div>
    }
</div>

<!-- Форма ввода -->
<form @onsubmit="SendMessage" class="chat-form">
    <textarea @bind="userInput"
              @onkeydown="HandleKey"
              placeholder="Введите сообщение... (Ctrl+Enter)"
              class="chat-input"
              disabled="@isGenerating"></textarea>
    <button type="submit"
            class="send-btn"
            disabled="@isGenerating || string.IsNullOrWhiteSpace(userInput)">
        Отправить
    </button>
</form>

<!-- Ошибки -->
@if (!string.IsNullOrEmpty(error))
{
    <div class="error-alert">❌ @error</div>
}

<!-- ⭐ Блок <style> УДАЛЕН — стили теперь в Home.razor.css -->
@code {
    private List<ChatMessage> history = new() { new("system", "Ты полезный ассистент. Отвечай кратко и по-русски.") };
    private string userInput = "", streamBuffer = "", error = "";
    private bool isGenerating = false;

    public class ChatMessage { public string Role { get; set; } public string Content { get; set; } public ChatMessage(string r, string c) { Role = r; Content = c; } }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGenerating) return;

        var question = userInput;
        userInput = "";
        streamBuffer = "";
        error = "";
        isGenerating = true;
        StateHasChanged();

        history.Add(new ChatMessage("user", question));

        try
        {
            Console.WriteLine("🚀 [DEBUG] Starting request...");

            using var handler = new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = HttpClientHandler.DangerousAcceptAnyServerCertificateValidator
            };
            using var client = new HttpClient(handler);
            client.Timeout = TimeSpan.FromMinutes(5);

            var apiKey = Config["Qwen:ApiKey"];
            var endpoint = Config["Qwen:Endpoint"];
            var model = Config["Qwen:Model"];

            Console.WriteLine($"🔑 [DEBUG] Endpoint: {endpoint}");
            Console.WriteLine($"🤖 [DEBUG] Model: {model}");

            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", apiKey);

            var payload = new
            {
                model = model,
                messages = history.Select(m => new { role = m.Role.ToLower(), content = m.Content }),
                stream = true
            };

            var json = JsonSerializer.Serialize(payload);
            var content = new StringContent(json, Encoding.UTF8, "application/json");

            Console.WriteLine($"📤 [DEBUG] Sending POST request...");

            using var response = await client.PostAsync(endpoint, content);

            Console.WriteLine($"📥 [DEBUG] Response received! Status: {(int)response.StatusCode}");

            if (!response.IsSuccessStatusCode)
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ [DEBUG] Error body: {errorBody}");
                error = $"HTTP {(int)response.StatusCode}: {errorBody}";
                StateHasChanged();
                return;
            }

            Console.WriteLine($"🌊 [DEBUG] Reading stream...");

            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            int tokenCount = 0;
            while (!reader.EndOfStream && isGenerating)
            {
                var line = await reader.ReadLineAsync();

                if (!string.IsNullOrWhiteSpace(line))
                {
                    var visible = line.Replace(" ", "•").Replace("\t", "→");
                    Console.WriteLine($"🔍 [RAW] Line: '{visible}' (len={line.Length})");
                }

                if (string.IsNullOrWhiteSpace(line)) continue;
                if (line.StartsWith(":")) continue;
                if (!line.TrimStart().StartsWith("data:")) continue;

                var dataStart = line.IndexOf("data: ");
                if (dataStart == -1) continue;

                var data = line.Substring(dataStart + 6).Trim();

                Console.WriteLine($"📦 [DATA] Parsed JSON: '{(data.Length > 100 ? data.Substring(0, 100) + "..." : data)}'");

                if (data == "[DONE]") break;

                try
                {
                    using var doc = JsonDocument.Parse(data);
                    var root = doc.RootElement;

                    if (root.TryGetProperty("choices", out var choices) && choices.GetArrayLength() > 0)
                    {
                        var delta = choices[0].GetProperty("delta");

                        if (delta.TryGetProperty("content", out var c) && c.ValueKind == JsonValueKind.String)
                        {
                            var token = c.GetString();
                            if (!string.IsNullOrEmpty(token))
                            {
                                streamBuffer += token;
                                tokenCount++;
                                Console.WriteLine($"🔤 [TOKEN] #{tokenCount}: '{token}'");

                                await InvokeAsync(StateHasChanged);
                                await Task.Delay(30);
                            }
                        }
                    }
                }
                catch (JsonException ex)
                {
                    Console.WriteLine($"❌ [JSON ERROR] {ex.Message}");
                }
            }

            Console.WriteLine($"📊 [DEBUG] Finished. Tokens: {tokenCount}, Buffer: '{streamBuffer}'");

            if (!string.IsNullOrEmpty(streamBuffer))
            {
                history.Add(new ChatMessage("assistant", streamBuffer));
                streamBuffer = "";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"💥 [DEBUG] Exception: {ex}");
            error = $"Ошибка: {ex.Message}";
            if (history.Count > 1) history.RemoveAt(history.Count - 1);
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey) await SendMessage();
    }
}