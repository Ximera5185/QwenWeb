@inject QwenWeb.Configuration.MonitorSettings MonitorSettings
@page "/monitor"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject QwenWeb.Data.TenderMonitorDbContext MonitorDb
@inject QwenWeb.Services.TenderMonitorBackgroundService MonitorService

<h3>📊 Тестовый мониторинг госзакупок</h3>

<div class="alert alert-warning mb-4">
    ⚠️ <strong>Экспериментальный модуль:</strong> @($"Опрос RSS каждые {MonitorSettings.PollIntervalMinutes} мин. Данные хранятся в отдельной БД monitor_test.db.")
</div>

<div class="mb-4 p-3 bg-light rounded">
    <div class="d-flex align-items-center gap-3">
        <label class="form-label mb-0 fw-bold">Интервал опроса:</label>
        <select class="form-select" @bind="MonitorSettings.PollIntervalMinutes" style="width: 160px;">
            <option value="5">5 минут (тест)</option>
            <option value="15">15 минут</option>
            <option value="30">30 минут (рекомендуется)</option>
            <option value="60">60 минут</option>
        </select>
        <small class="text-muted">Изменение применится к следующему циклу.</small>
    </div>
</div>

<div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <strong>Всего опросов:</strong> @MonitorService.TotalPollsCount.ToString()<br />
        <strong>Последний запуск:</strong> @(MonitorService.LastRunTimeUtc == DateTime.MinValue ? "Ещё не запускался" : MonitorService.LastRunTimeUtc.ToString("dd.MM.yyyy HH:mm"))<br />
        <strong>Найдено за раз:</strong>
        @if (MonitorService.IsErrorLastRun)
        {
            <span class="text-danger fw-bold">Ошибка сети (возможно 403)</span>
        }
        else
        {
            @(MonitorService.NewTendersFoundLastRun == 0 ? "0 новых" : MonitorService.NewTendersFoundLastRun.ToString() + " новых")
        }
        <br />
        <strong>Всего в базе:</strong> @totalCount.ToString()
    </div>
    <button class="btn btn-outline-primary" @onclick="RunManualCheck" disabled="@(MonitorService.LastRunTimeUtc > DateTime.UtcNow.AddMinutes(-1))">
        🔄 Проверить сейчас
    </button>
</div>

@if (tenders.Count == 0)
{
    <div class="text-center py-5">
        <p class="text-muted">Загрузка данных из базы или ожидание первого цикла мониторинга...</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (QwenWeb.Models.TenderMonitorRecord t in tenders.OrderByDescending(x => x.PubDate).ThenByDescending(x => x.CreatedAtUtc))
        {
            <a href="@t.Link" target="_blank" rel="noopener" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h6 class="mb-1">@t.Title</h6>
                    <small class="text-muted">@(t.PubDate?.ToString("dd.MM.yyyy") ?? "Нет даты")</small>
                </div>
                @if (!string.IsNullOrEmpty(t.Description))
                {
                    <p class="mb-1 text-secondary" style="font-size: 0.85rem; max-height: 60px; overflow: hidden;">
                        @((MarkupString)t.Description)
                    </p>
                }
            </a>
        }
    </div>
}

@code {
    private List<QwenWeb.Models.TenderMonitorRecord> tenders = new List<QwenWeb.Models.TenderMonitorRecord>();
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadFromDatabaseAsync();
    }

    private async Task LoadFromDatabaseAsync()
    {
        tenders = await MonitorDb.Tenders.ToListAsync();
        totalCount = tenders.Count;
        StateHasChanged();
    }

    private async Task RunManualCheck()
    {
        await MonitorService.RunManualAsync();
        await LoadFromDatabaseAsync();
    }
}