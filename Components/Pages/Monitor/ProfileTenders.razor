@page "/monitor/profiles/{ProfileId:int}/tenders"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using QwenWeb.Data
@using QwenWeb.Models

@inject TenderMonitorDbContext Db
@inject NavigationManager Navigation

<h3>🔍 Закупки профиля: @profileName</h3>

<!-- Фильтры и пагинация -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text" class="form-control form-control-sm"
                       placeholder="Поиск по названию..."
                       @bind="searchQuery"
                       @bind:event="oninput" />
            </div>
            <div class="col-md-2">
                <select class="form-select form-select-sm" @bind="pageSize">
                    <option value="10">10 на стр.</option>
                    <option value="25">25 на стр.</option>
                    <option value="50">50 на стр.</option>
                    <option value="100">100 на стр.</option>
                </select>
            </div>
            <div class="col-md-6 text-md-end">
                <small class="text-muted">
                    Найдено: @totalCount | Страница @currentPage из @totalPages
                </small>
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Загрузка закупок...</p>
    </div>
}
else if (items.Count == 0)
{
    <div class="alert alert-info">
        @(string.IsNullOrEmpty(searchQuery)
            ? "По этому профилю пока нет сохранённых закупок."
            : "Ничего не найдено по вашему запросу.")
    </div>
}
else
{
    <div class="list-group">
        @foreach (var item in items)
        {
            <QwenWeb.Components.TenderCard Item="item" />
        }
    </div>

    <!-- Пагинация -->
    @if (totalPages > 1)
    {
        <nav class="mt-3" aria-label="Пагинация">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage == 1)">← Назад</button>
                </li>
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage == totalPages)">Вперёд →</button>
                </li>
            </ul>
        </nav>
    }
}

<!-- Кнопка назад -->
<div class="mt-4">
    <a href="/monitor/dashboard" class="btn btn-outline-secondary btn-sm">← Назад к профилям</a>
</div>

@code {
    [Parameter] public int ProfileId { get; set; }

    private string profileName = "Загрузка...";
    private List<TenderDisplayItem> items = new();
    private bool isLoading = true;

    // Пагинация и поиск
    private string searchQuery = string.Empty;
    private int pageSize = 25;
    private int currentPage = 1;
    private int totalCount = 0;
    private int totalPages => totalCount == 0 ? 1 : (int)Math.Ceiling(totalCount / (double)pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileNameAsync();
        await LoadTendersAsync();
    }

    private async Task LoadProfileNameAsync()
    {
        var profile = await Db.MonitorProfiles.FindAsync(ProfileId);
        profileName = profile?.Name ?? $"Профиль #{ProfileId}";
    }

    private async Task LoadTendersAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var query = Db.Tenders
                .Where(t => t.ProfileId == ProfileId)
                .AsQueryable();

            // Поиск по названию/описанию
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var q = searchQuery.ToLower();
                query = query.Where(t =>
                    (t.Title != null && t.Title.ToLower().Contains(q)) ||
                    (t.Description != null && t.Description.ToLower().Contains(q)));
            }

            totalCount = await query.CountAsync();

            if (currentPage > totalPages) currentPage = Math.Max(1, totalPages);

            var records = await query
                .OrderByDescending(t => t.PubDate)
                .ThenByDescending(t => t.CreatedAtUtc)
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToListAsync();

            items = records.Select(r => new TenderDisplayItem
            {
                Record = r,
                ParsedInfo = r.Description != null
                    ? QwenWeb.Services.Parsing.TenderInfoParser.Parse(r.Description)
                    : null
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR] LoadTendersAsync: {ex.Message}");
            items = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        _ = LoadTendersAsync();
    }

    // 🔹 убран OnParametersSetAsync — чтобы не было перезагрузок при вводе поиска
    // поиск работает через @bind:event="oninput" + StateHasChanged в LoadTendersAsync
}